# Tracked intentionally so the npm package ships with the built CSS:
#   - styles/vanilla-combined.min.css (the published artifact)
#   - styles/themes/{legacy,helix}.min.css (distributable theme files)
# These are regenerated by `npm run build:css`. If you'd rather rebuild
# on CI instead of committing build output, uncomment the lines below
# and wire the build into the deploy workflow.
# styles/vanilla-combined.min.css
# styles/themes/*.min.css
# tokens/*.json

